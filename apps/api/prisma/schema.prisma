generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        BigInt     @id
  user      String     @unique
  password  String
  isOwner   Boolean?
  roles     UserRole[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Role {
  id          BigInt  @id
  name        String  @default("New Role")
  description String?
  hierarchy   Int?    @unique
  permissions Int @default(0)
  users UserRole[]
}

model UserRole {
  id     BigInt @id
  userId BigInt
  roleId BigInt
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}
